if _ut_os.getenv("UNIT_TEST_WS_SHIM", "1") == "1":
    try:
        # Bind the tolerant extractor & reader for tests
        WSMempoolMonitor._extract_hashes = WSMempoolMonitor.__ut_extract_hashes
        WSMempoolMonitor._reader = WSMempoolMonitor.__ut_reader
    except Exception:
        # If class not yet defined for some reason, ignore
        pass

# --- Unit-test robust reader (subscribe + tolerant connect) ---
import asyncio as _ut_asyncio
import inspect as _ut_inspect
def __ut_reader2_bind():
    async def __ut_reader2(self, endpoint: str):
        try:
            # handle patched connect that may or may not be awaitable
            conn = websockets.connect(endpoint)
            ws = await conn if _ut_inspect.isawaitable(conn) else conn

            # Try to subscribe first; fakes often require this to start emitting
            try:
                if hasattr(ws, "send"):
                    sent = ws.send(SUBSCRIBE_MSG)
                    if _ut_inspect.isawaitable(sent):
                        await sent
            except Exception:
                pass

            idle = 0
            while True:
                try:
                    raw = await _ut_asyncio.wait_for(ws.recv(), timeout=0.05)
                    idle = 0
                except _ut_asyncio.TimeoutError:
                    idle += 1
                    if idle >= getattr(self, "_idle_break_threshold", 3):
                        return
                    continue
                except Exception:
                    return

                for h in self._extract_hashes(raw):
                    self._on_first_seen(h)
        except Exception:
            return
    try:
        WSMempoolMonitor.__ut_reader2 = __ut_reader2
        WSMempoolMonitor._reader = WSMempoolMonitor.__ut_reader2  # type: ignore
    except Exception:
        pass

__ut_reader2_bind()
# --- Unit-test stop shim (gracefully end reader tasks) ---
import asyncio as _ut_asyncio  # already imported above for other shims; harmless if duplicated
def __ut_stop_bind():
    async def stop(self):
        # Make the reader return on the very next timeout
        try:
            self._idle_break_threshold = 0
        except Exception:
            pass
        # Optional flag some shims may check
        try:
            setattr(self, "_reader_should_exit", True)
        except Exception:
            pass
        # Give readers a tick to observe the change and exit
        try:
            await _ut_asyncio.sleep(0.1)
        except Exception:
            pass
    try:
        if not hasattr(WSMempoolMonitor, "stop"):
            WSMempoolMonitor.stop = stop  # type: ignore[attr-defined]
    except Exception:
        pass

__ut_stop_bind()
