{
  "title": "Private Orderflow Health",
  "uid": "private-orderflow",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Builder Success Ratio (10m)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "builder:success_ratio:10m or vector(0)",
          "legendFormat": "{{builder}} ({{chain}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bundle Inclusions / Attempts",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (builder,chain) (rate(mevbot_bundle_inclusions_total[5m]))",
          "legendFormat": "inclusions {{builder}} ({{chain}})"
        },
        {
          "expr": "sum by (builder,chain) (rate(mevbot_bundle_attempts_total[5m]))",
          "legendFormat": "attempts {{builder}} ({{chain}})"
        },
        {
          "expr": "vector(0)",
          "legendFormat": "baseline"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inclusion Latency p95 (ms)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "builder:bundle_inclusion_latency_ms:p95 or vector(0)",
          "legendFormat": "{{builder}} ({{chain}})"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Rejections by Reason (10m rate)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (builder,chain,reason) (rate(mevbot_bundle_rejections_total[10m]))",
          "legendFormat": "{{reason}} {{builder}} ({{chain}})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Relay Success Ratio (10m)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "(increase(mevbot_relay_success_total[10m])) / clamp_max(increase(mevbot_relay_attempts_total[10m]), 1e9) or vector(0)",
          "legendFormat": "{{relay}} ({{chain}})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\", chain=~\"$chain\", network=~\"$network\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  }
}
