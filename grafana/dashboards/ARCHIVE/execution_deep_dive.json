{
  "id": null,
  "uid": "execution-deep-dive",
  "title": "Execution Deep Dive",
  "schemaVersion": 39,
  "version": 2,
  "timezone": "browser",
  "refresh": "10s",
  "tags": [
    "execution",
    "mevbot",
    "golden"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "bargauge",
      "title": "Revert Reasons (10m)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(mevbot_tx_revert_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[10m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Sim Fail Reasons (10m)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(mevbot_sim_fail_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"}[10m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPC Error Rate by Provider (5m)",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, code_bucket) (rate(mevbot_rpc_errors_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m]))",
          "legendFormat": "{{provider}} {{code_bucket}}"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Confirm Latency Histogram",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 14,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(mevbot_tx_confirm_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m]))",
          "format": "heatmap"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Head/Slot Lag",
      "gridPos": {
        "x": 14,
        "y": 7,
        "w": 10,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (provider) (mevbot_head_lag_blocks{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"})",
          "legendFormat": "head_lag {{provider}}"
        },
        {
          "refId": "B",
          "expr": "max by (provider) (mevbot_slot_lag{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"})",
          "legendFormat": "slot_lag {{provider}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\", chain=~\"$chain\", network=~\"$network\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    }
  ]
}
