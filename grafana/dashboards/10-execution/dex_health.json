{
  "id": null,
  "uid": "dex-health",
  "title": "DEX Health",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "tags": [
    "dex",
    "execution",
    "mevbot"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Quote Latency p95 by DEX (s)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, dex) (rate(mevbot_dex_quote_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])))",
          "legendFormat": "{{dex}} p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quote Latency p99 by DEX (s)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le, dex) (rate(mevbot_dex_quote_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])))",
          "legendFormat": "{{dex}} p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quote Fail Rate by DEX (5m)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (rate(mevbot_dex_quote_fail_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])) / clamp_min(sum by (dex) (rate(mevbot_dex_quote_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])), 1e-9)",
          "legendFormat": "{{dex}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Sim Fail Rate by DEX (5m)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (rate(mevbot_dex_sim_fail_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])) / clamp_min(sum by (dex) (rate(mevbot_dex_quote_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[5m])), 1e-9)",
          "legendFormat": "{{dex}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Router Best DEX Selected (10m)",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (increase(mevbot_router_best_dex_selected_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "{{dex}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\", chain=~\"$chain\", network=~\"$network\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    }
  ]
}
