{
  "id": null,
  "uid": "dex-performance",
  "title": "DEX Performance",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "tags": [
    "dex",
    "strategy",
    "mevbot"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "PnL / Fees / Drawdown by DEX (live when labeled)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "expr": "sum by (dex) (mevbot_pnl_realized_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}) or sum by (dex) (0 * mevbot_dex_quote_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"})"
        },
        {
          "refId": "B",
          "format": "table",
          "expr": "sum by (dex) (mevbot_fees_total_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}) or sum by (dex) (0 * mevbot_dex_quote_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"})"
        },
        {
          "refId": "C",
          "format": "table",
          "expr": "max by (dex) (mevbot_drawdown_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}) or sum by (dex) (0 * mevbot_dex_quote_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"})"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Slippage Histogram by DEX (if available)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le, dex) (rate(mevbot_slippage_bps_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m])) or on() vector(0)"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Price Impact Histogram by DEX (if available)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le, dex) (rate(mevbot_price_impact_bps_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m])) or on() vector(0)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DEX Fill Funnel (10m increase)",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (increase(mevbot_opportunities_seen_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "{{dex}} seen"
        },
        {
          "refId": "B",
          "expr": "sum by (dex) (increase(mevbot_opportunities_attempted_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "{{dex}} attempted"
        },
        {
          "refId": "C",
          "expr": "sum by (dex) (increase(mevbot_opportunities_filled_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "{{dex}} filled"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\", chain=~\"$chain\", network=~\"$network\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    }
  ]
}
