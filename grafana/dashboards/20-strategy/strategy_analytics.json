{
  "id": null,
  "uid": "strategy-analytics",
  "title": "Strategy Analytics",
  "schemaVersion": 39,
  "version": 2,
  "timezone": "browser",
  "refresh": "15s",
  "tags": [
    "strategy",
    "analytics",
    "mevbot",
    "golden"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "PnL by Strategy/DEX/Chain",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "expr": "sum by (strategy, chain) (mevbot_pnl_realized_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"})"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Edge Histogram (if available)",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le) (rate(mevbot_edge_bps_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Slippage Histogram (if available)",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le) (rate(mevbot_slippage_bps_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Filter Reason Pareto (24h)",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(12, sum by (reason) (increase(mevbot_sim_fail_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"}[24h])))",
          "legendFormat": "sim_fail {{reason}}"
        },
        {
          "refId": "B",
          "expr": "topk(12, sum by (reason) (increase(mevbot_tx_revert_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[24h])))",
          "legendFormat": "revert {{reason}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\", chain=~\"$chain\", network=~\"$network\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    }
  ]
}
