{
  "id": null,
  "uid": "strategy-analytics",
  "title": "20 Strategy Analytics",
  "schemaVersion": 39,
  "version": 3,
  "timezone": "browser",
  "refresh": "30s",
  "tags": [
    "golden",
    "deep-dive",
    "strategy",
    "risk",
    "evm",
    "sol"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "PnL by Strategy/DEX/Chain",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "expr": "sum by (strategy, chain) (mevbot_pnl_realized_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"})"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "DEX Quote Latency Histogram (p95 view)",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le, dex) (rate(mevbot_dex_quote_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Route Hops Histogram",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "heatmap",
          "expr": "sum by (le, dex) (rate(mevbot_dex_route_hops_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Filter Reason Pareto (24h)",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(12, sum by (reason) (increase(mevbot_sim_fail_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"}[24h])))",
          "legendFormat": "sim_fail {{reason}}"
        },
        {
          "refId": "B",
          "expr": "topk(12, sum by (reason) (increase(mevbot_tx_revert_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[24h])))",
          "legendFormat": "revert {{reason}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Live (s)",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\",provider=~\"$provider\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present (mevbot_*)",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count({__name__=~\"mevbot_.*\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: Target Up (mev-bot)",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"mev-bot\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: Exporter Live (s)",
      "gridPos": {
        "x": 8,
        "y": 26,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: mevbot_* Count",
      "gridPos": {
        "x": 16,
        "y": 26,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count({__name__=~\"mevbot_.*\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Attempts by Strategy (10m)",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy) (increase(mevbot_opportunities_attempted_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Attempts by DEX (10m)",
      "gridPos": {
        "x": 12,
        "y": 30,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (increase(mevbot_opportunities_attempted_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    }
  ]
}
