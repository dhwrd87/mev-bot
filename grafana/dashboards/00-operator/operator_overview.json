{
  "id": null,
  "uid": "operator-overview",
  "title": "00 Operator Overview",
  "schemaVersion": 39,
  "version": 3,
  "timezone": "browser",
  "refresh": "30s",
  "tags": [
    "golden",
    "ops",
    "execution",
    "rpc",
    "risk",
    "evm",
    "sol"
  ],
  "templating": {
    "list": [
      {
        "name": "family",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, family)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "chain",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, chain)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, network)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "dex",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, dex)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "strategy",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, strategy)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mevbot_heartbeat_ts, provider)",
        "includeAll": true,
        "customAllValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Bot State",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mevbot_bot_state_value{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "UNKNOWN"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "PAUSED"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "READY"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "text": "TRADING"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "4": {
                  "text": "DEGRADED"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "5": {
                  "text": "PANIC"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Tx Failure Rate Last 10m",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(mevbot_tx_failed_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[10m])) / clamp_min(sum(increase(mevbot_tx_sent_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[10m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3
        }
      }
    },
    {
      "type": "stat",
      "title": "Exporter Live (s)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\",provider=~\"$provider\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "orange",
                "value": 120
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "PnL Today + Drawdown (USD)",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mevbot_pnl_realized_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"})",
          "legendFormat": "pnl_realized"
        },
        {
          "refId": "B",
          "expr": "max(mevbot_drawdown_usd{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"})",
          "legendFormat": "drawdown"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RPC p95/p99 Latency by Provider (s)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(mevbot_rpc_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m])))",
          "legendFormat": "{{provider}} p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(mevbot_rpc_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m])))",
          "legendFormat": "{{provider}} p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Confirm Latency p95 (s)",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mevbot_tx_confirm_latency_seconds_bucket{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m])))",
          "legendFormat": "confirm_p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Opportunities Funnel (10m increase)",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(mevbot_opportunities_seen_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "seen"
        },
        {
          "refId": "B",
          "expr": "sum(increase(mevbot_opportunities_attempted_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "attempted"
        },
        {
          "refId": "C",
          "expr": "sum(increase(mevbot_opportunities_filled_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\",dex=~\"$dex\"}[10m]))",
          "legendFormat": "filled"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Target Up (mev-bot)",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"mev-bot\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Outcomes By Mode (10m increase)",
      "gridPos": {
        "x": 6,
        "y": 21,
        "w": 18,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode, outcome) (increase(mevbot_mode_outcomes_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[10m]))",
          "legendFormat": "{{mode}}/{{outcome}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Metrics Present (mevbot_*)",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count({__name__=~\"mevbot_.*\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Desired vs Effective",
      "gridPos": {
        "x": 6,
        "y": 25,
        "w": 18,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mevbot_desired_chain_info{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "desired_chain_info"
        },
        {
          "refId": "B",
          "expr": "max(mevbot_effective_chain_info{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "effective_chain_info"
        },
        {
          "refId": "C",
          "expr": "max(mevbot_desired_state_value{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "desired_state"
        },
        {
          "refId": "D",
          "expr": "max(mevbot_effective_state_value{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "effective_state"
        },
        {
          "refId": "E",
          "expr": "max(mevbot_desired_mode_info{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "desired_mode"
        },
        {
          "refId": "F",
          "expr": "max(mevbot_effective_mode_info{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)",
          "legendFormat": "effective_mode"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: Target Up (mev-bot)",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"mev-bot\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: Exporter Live (s)",
      "gridPos": {
        "x": 8,
        "y": 31,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(mevbot_heartbeat_ts{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Metrics Present: mevbot_* Count",
      "gridPos": {
        "x": 16,
        "y": 31,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count({__name__=~\"mevbot_.*\"}) or vector(0)"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Head and Lag by Provider",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (provider) (mevbot_chain_head{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"})"
        },
        {
          "refId": "B",
          "expr": "max by (provider) (mevbot_head_lag_blocks{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"})"
        },
        {
          "refId": "C",
          "expr": "max(mevbot_head) or vector(0)",
          "legendFormat": "head_direct"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Opportunities Seen by Strategy (10m)",
      "gridPos": {
        "x": 12,
        "y": 35,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy) (increase(mevbot_opportunities_seen_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",strategy=~\"$strategy\"}[10m])) or vector(0)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Opportunities Seen by DEX (10m)",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dex) (increase(mevbot_opportunities_seen_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",dex=~\"$dex\"}[10m])) or vector(0)"
        }
      ]
    }
  ]
}
