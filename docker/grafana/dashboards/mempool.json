{
  "id": null,
  "uid": "mempool-pipeline-live",
  "title": "Mempool Pipeline Live",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Targets Up",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 6},
      "targets": [
        {"expr": "sum(up{job=~\"mev-bot|prometheus|alertmanager\"})", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "textMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "Mempool Stream XLEN",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 6},
      "targets": [
        {"expr": "max(mevbot_mempool_stream_xlen{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",stream=\"mempool:pending:txs\"})", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "Producer WS Reconnects (5m)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum by(endpoint) (increase(mevbot_mempool_reconnects_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",endpoint=~\"$endpoint\"}[5m]))", "legendFormat": "{{endpoint}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer fetch_tx OK Rate",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(mevbot_rpc_gettx_ok_total[1m]))", "legendFormat": "ok/s", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer Errors Rate",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(mevbot_rpc_gettx_429_total[5m]))", "legendFormat": "429/s", "refId": "A"},
        {"expr": "sum(rate(mevbot_rpc_gettx_errors_total[5m]))", "legendFormat": "rpc_errors/s", "refId": "B"},
        {"expr": "sum(rate(mevbot_mempool_stream_consume_errors_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m]))", "legendFormat": "consume_errors/s", "refId": "C"},
        {"expr": "sum by(kind) (rate(mevbot_mempool_stream_consume_errors_total{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}[5m]))", "legendFormat": "{{kind}}/s", "refId": "D"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Stream Group Lag",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "targets": [
        {"expr": "max(mevbot_mempool_stream_group_lag{family=~\"$family\",chain=~\"$chain\",network=~\"$network\",stream=\"mempool:pending:txs\",group=\"mempool\"})", "legendFormat": "mempool group lag", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "Bot State (enum)",
      "gridPos": {"x": 0, "y": 22, "w": 8, "h": 6},
      "targets": [
        {"expr": "max by(state) (bot_state{chain_family=\"evm\"})", "legendFormat": "{{state}}", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "name"}
    },
    {
      "type": "timeseries",
      "title": "Trades Sent/Failed",
      "gridPos": {"x": 8, "y": 22, "w": 8, "h": 6},
      "targets": [
        {"expr": "sum(rate(trades_sent_total{chain_family=\"evm\"}[5m]))", "legendFormat": "sent/s", "refId": "A"},
        {"expr": "sum(rate(trades_failed_total{chain_family=\"evm\"}[5m]))", "legendFormat": "failed/s", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "RPC Latency p95 (s)",
      "gridPos": {"x": 16, "y": 22, "w": 8, "h": 6},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(rpc_latency_seconds_bucket{chain_family=\"evm\"}[5m])))", "legendFormat": "p95", "refId": "A"}
      ]
    }
  ],
  "templating": {"list": [
    {
      "name": "family",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(mevbot_heartbeat_ts, family)",
      "includeAll": true,
      "customAllValue": ".*",
      "multi": false,
      "current": {"selected": true, "text": "All", "value": "$__all"}
    },
    {
      "name": "chain",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(mevbot_heartbeat_ts, chain)",
      "includeAll": true,
      "customAllValue": ".*",
      "multi": false,
      "current": {"selected": true, "text": "All", "value": "$__all"}
    },
    {
      "name": "network",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(mevbot_heartbeat_ts, network)",
      "includeAll": true,
      "customAllValue": ".*",
      "multi": false,
      "current": {"selected": true, "text": "All", "value": "$__all"}
    },
    {
      "name": "endpoint",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(mevbot_mempool_ws_connected{family=~\"$family\",chain=~\"$chain\",network=~\"$network\"}, endpoint)",
      "includeAll": true,
      "customAllValue": ".*",
      "multi": true,
      "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
    }
  ]},
  "annotations": {"list": []}
}
